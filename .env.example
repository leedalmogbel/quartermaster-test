# ============================================
# QUARTERMASTER ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ---- REQUIRED ----

# JWT Secret for user authentication (generate a random 32+ char string)
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# AES-256-GCM field-level encryption key (64-character random hex string)
ENCRYPTION_KEY=64-character-random-hex-string-for-aes-256-encryption

# Allowed CORS origins (comma-separated, no trailing slash)
ALLOWED_ORIGINS=https://your-railway-domain.up.railway.app

# Claude AI (for CFO script generation)
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ---- OPTIONAL (enable when ready) ----

# QuickBooks Online
# Setup: https://developer.intuit.com → Create App → Keys & Credentials
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=https://your-domain.com/api/quickbooks/callback
QB_ENVIRONMENT=sandbox

# Google Ads
# Setup: https://console.cloud.google.com → APIs → Google Ads API
# Developer token: https://developers.google.com/google-ads/api/docs/get-started/dev-token
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REDIRECT_URI=https://your-domain.com/api/google-ads/callback

# Facebook/Meta Ads
# Setup: https://developers.facebook.com → Create App → Marketing API
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=https://your-domain.com/api/facebook-ads/callback

# ---- SERVER ----
PORT=5000
NODE_ENV=production
